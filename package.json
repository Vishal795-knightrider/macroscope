{
  "name": "macroscope-performance-os",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron-main/main.js",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "desktop:dev": "npx concurrently -k -n VITE,ELECTRON -c cyan,yellow \"vite --config vite.electron.config.ts\" \"npx electron .\"",
    "desktop:build-renderer": "vite build --config vite.electron.config.ts",
    "desktop:build-main": "tsc --project tsconfig.electron.json",
    "desktop:build": "npm run desktop:build-renderer && npm run desktop:build-main",
    "desktop:start": "npm run desktop:build && electron .",
    "desktop:dist": "npm run desktop:build && electron-builder"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.5",
    "@mui/material": "7.3.5",
    "@popperjs/core": "2.11.8",
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.2",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-collapsible": "1.1.3",
    "@radix-ui/react-context-menu": "2.2.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-hover-card": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-menubar": "1.1.6",
    "@radix-ui/react-navigation-menu": "1.2.5",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toggle": "1.1.2",
    "@radix-ui/react-toggle-group": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "@supabase/supabase-js": "^2.101.1",
    "canvas-confetti": "1.9.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "3.6.0",
    "electron-squirrel-startup": "^1.0.1",
    "embla-carousel-react": "8.6.0",
    "expo-android-usagestats": "^1.2.0",
    "expo-intent-launcher": "^55.0.11",
    "input-otp": "1.4.2",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "next-themes": "0.4.6",
    "react": "18.3.1",
    "react-day-picker": "8.10.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.55.0",
    "react-popper": "2.3.0",
    "react-resizable-panels": "2.1.7",
    "react-responsive-masonry": "2.7.1",
    "react-router": "7.13.0",
    "react-slick": "0.31.0",
    "recharts": "2.15.2",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "^9.1.2",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "tailwindcss": "4.1.12",
    "typescript": "^5.7.3",
    "vite": "^6.4.2",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.ascendancy.macroscope",
    "productName": "MacroScope",
    "copyright": "Copyright © 2026 Ascendancy",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist-electron-renderer/**/*",
      "dist-electron-main/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.healthcare-fitness"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    }
  }
}
